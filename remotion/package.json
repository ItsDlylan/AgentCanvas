{
  "name": "agentcanvas-remotion",
  "version": "0.1.0",
  "private": true,
  "description": "Motion-graphics compositions for AgentCanvas tutorial videos.",
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render:welcome": "remotion render src/index.ts Welcome ../src/renderer/public/tutorials/welcome.mp4",
    "render:welcome:poster": "remotion still src/index.ts Welcome ../src/renderer/public/tutorials/welcome.jpg --frame=30"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.450",
    "@remotion/cli": "4.0.450",
    "@remotion/renderer": "4.0.450",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.450"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.4.0"
  }
}
